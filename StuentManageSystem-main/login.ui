<ui version="4.0">
 <class>login</class>
 <widget class="QDialog" name="login">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>450</width>
    <height>420</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>人员信息管理系统</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QDialog {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #667eea, stop:1 #764ba2);
}

QFrame#loginFrame {
    background-color: rgba(255, 255, 255, 0.98);
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
}

QLabel#label_icon {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #667eea, stop:1 #764ba2);
    border-radius: 50%;
}

QLabel#label_title {
    font-size: 26px;
    font-weight: bold;
    color: #1a202c;
    letter-spacing: 2px;
}

QLabel#label_subtitle {
    font-size: 13px;
    color: #718096;
}

QLineEdit {
    border: none;
    border-bottom: 2px solid #e2e8f0;
    background-color: transparent;
    padding: 12px 0 8px 0;
    font-size: 15px;
    color: #2d3748;
}

QLineEdit:focus {
    border-bottom-color: #667eea;
    outline: none;
}

QLineEdit::placeholder {
    color: #a0aec0;
}

QPushButton#btn_login {
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #667eea, stop:1 #764ba2);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 14px 0;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 1px;
}

QPushButton#btn_login:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
}

QPushButton#btn_exit {
    background-color: #edf2f7;
    color: #4a5568;
    border: none;
    border-radius: 10px;
    padding: 12px 0;
    font-size: 14px;
}

QPushButton#btn_exit:hover {
    background-color: #e2e8f0;
}
   </string>
  </property>
